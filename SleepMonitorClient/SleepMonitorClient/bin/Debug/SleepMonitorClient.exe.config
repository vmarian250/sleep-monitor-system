<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <system.serviceModel>
        <bindings>
            <basicHttpBinding>
                <binding name="SleepServiceSoap">
                    <security mode="Transport" />
                </binding>
                <binding name="SleepServiceSoap1" />
                <binding name="SleepServiceSoap2">
                    <security mode="Transport" />
                </binding>
                <binding name="SleepServiceSoap3" />
                <binding name="SleepServiceSoap4">
                    <security mode="Transport" />
                </binding>
                <binding name="SleepServiceSoap5" />
            </basicHttpBinding>
            <customBinding>
                <binding name="SleepServiceSoap12">
                    <textMessageEncoding messageVersion="Soap12" />
                    <httpsTransport />
                </binding>
            </customBinding>
        </bindings>
        <client>
            <endpoint address="https://localhost:44397/SleepService.asmx"
                binding="basicHttpBinding" bindingConfiguration="SleepServiceSoap"
                contract="ServiceReference1.SleepServiceSoap" name="SleepServiceSoap" />
            <endpoint address="https://localhost:44397/SleepService.asmx"
                binding="basicHttpBinding" bindingConfiguration="SleepServiceSoap2"
                contract="SleepServiceRef.SleepServiceSoap" name="SleepServiceSoap1" />
            <endpoint address="https://localhost:44397/SleepService.asmx"
                binding="basicHttpBinding" bindingConfiguration="SleepServiceSoap4"
                contract="ServiceReference.SleepServiceSoap" name="SleepServiceSoap2" />
            <endpoint address="https://localhost:44397/SleepService.asmx"
                binding="customBinding" bindingConfiguration="SleepServiceSoap12"
                contract="ServiceReference.SleepServiceSoap" name="SleepServiceSoap12" />
        </client>
    </system.serviceModel>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>